# ─── Discord application (Developer Portal → your app) ───────────────────────
# General Information page:
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
# Bot page → Reset Token:
DISCORD_BOT_TOKEN=
# OAuth2 page (Client ID == App ID):
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── Mirror channel (a SEPARATE Discord channel's webhook URL) ───────────────
# Fallback used when a connected server has no per-server mirror configured.
# Channel → Edit → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_MIRROR_WEBHOOK_URL=

# ─── Database (Neon Postgres connection string) ──────────────────────────────
DATABASE_URL=

# ─── AI triage (Google AI Studio → Create API key) ──────────────────────────
GEMINI_API_KEY=
# Optional model override (defaults to gemini-2.5-flash):
GEMINI_MODEL=gemini-2.5-flash

# ─── App / auth ──────────────────────────────────────────────────────────────
# Public base URL of the deployed app (used for OAuth redirect + follow-ups).
# Locally this is http://localhost:3000 ; on Render it's your service URL.
PUBLIC_BASE_URL=http://localhost:3000
# Long random string — generate with: openssl rand -hex 32
SESSION_SECRET=
# Seeded admin login for the dashboard (throwaway account):
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# Server port (Render sets this automatically):
PORT=3000
NODE_ENV=development
